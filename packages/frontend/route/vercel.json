{
  "rewrites": [
    { "source": "/landing/_next/static/:path*", "destination": "https://landing-project.vercel.app/_next/static/:path*" },
    { "source": "/_next/static/:path*", "destination": "https://main-project.vercel.app/_next/static/:path*" },
    { "source": "/", "destination": "https://landing-project.vercel.app" },
    { "source": "/:path*", "destination": "https://main-project.vercel.app/:path*" }
  ]
}



