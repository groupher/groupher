{
  "extends": "@groupher/frontend-config/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/hooks": ["./hooks"],
      "~/hooks/*": ["./hooks/*"],
      "~/utils": ["./utils"],
      "~/utils/*": ["./utils/*"],
      "~/server": ["./utils/api"],
      "~/server/*": ["./utils/api/*"],
      "~/signal": ["./utils/signal"],
      "~/signal/*": ["./utils/signal/*"],
      "~/dom": ["./utils/dom"],
      "~/dom/*": ["./utils/dom/*"],
      "~/logger": ["./utils/logger"],
      "~/logger/*": ["./utils/logger/*"],
      "~/fmt": ["./utils/fmt"],
      "~/fmt/*": ["./utils/fmt/*"],
      "~/oauth": ["./utils/oauth"],
      "~/oauth/*": ["./utils/oauth/*"],
      "~/helper": ["./utils/helper"],
      "~/helper/*": ["./utils/helper/*"],
      "~/wallpaper": ["./utils/wallpaper"],
      "~/wallpaper/*": ["./utils/wallpaper/*"],
      "~/i18n": ["./utils/i18n"],
      "~/i18n/*": ["./utils/i18n/*"],
      "~/validator": ["./utils/validator"],
      "~/validator/*": ["./utils/validator/*"],
      "~/mock": ["./utils/mock"],
      "~/mock/*": ["./utils/mock/*"],
      "~/css": ["./utils/css"],
      "~/css/*": ["./utils/css/*"],
      "~/schemas": ["./schemas"],
      "~/spec": ["./spec"],
      "~/icons": ["./Icons"],
      "~/icons/*": ["./Icons/*"],
      "~/containers": ["./containers"],
      "~/containers/*": ["./containers/*"],
      "~/widgets/*": ["./widgets/*"],
      "~/Img": ["./widgets/Img"],
      "~/const": ["./constant/"],
      "~/const/*": ["./constant/*"],
      "~/stores/*": ["./stores/*"],
      "~/stores": ["./stores"],

      "~/config": ["./config"]
    }
  },
  "include": ["next-env.d.ts", "**/*.tsx", "**/*.ts", ".next/types/**/*.ts"]
}
