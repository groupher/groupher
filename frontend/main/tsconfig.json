{
  "extends": "@groupher/frontend-config/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/hooks": ["../shared//hooks"],
      "~/hooks/*": ["../shared/hooks/*"],
      "~/config": ["config"],
      "~/stores/*": ["src/stores/*"],
      "~/stores": ["src/stores"],
      "~/utils": ["../shared/utils"],
      "~/utils/*": ["../shared/utils/*"],
      "~/server": ["../shared/utils/api"],
      "~/server/*": ["../shared/utils/api/*"],
      "~/signal": ["../shared/utils/signal"],
      "~/signal/*": ["../shared/utils/signal/*"],
      "~/dom": ["../shared/utils/dom"],
      "~/dom/*": ["../shared/utils/dom/*"],
      "~/logger": ["../shared/utils/logger"],
      "~/logger/*": ["../shared/utils/logger/*"],
      "~/fmt": ["../shared/utils/fmt"],
      "~/fmt/*": ["../shared/utils/fmt/*"],
      "~/oauth": ["../shared/utils/oauth"],
      "~/oauth/*": ["../shared/utils/oauth/*"],
      "~/helper": ["../shared/utils/helper"],
      "~/helper/*": ["../shared/utils/helper/*"],
      "~/wallpaper": ["../shared/utils/wallpaper"],
      "~/wallpaper/*": ["../shared/utils/wallpaper/*"],
      "~/i18n": ["../shared/utils/i18n"],
      "~/i18n/*": ["../shared/utils/i18n/*"],
      "~/validator": ["../shared/utils/validator"],
      "~/validator/*": ["../shared/utils/validator/*"],
      "~/mock": ["../shared/utils/mock"],
      "~/mock/*": ["../shared/utils/mock/*"],
      "~/css": ["../shared/utils/css"],
      "~/css/*": ["../shared/utils/css/*"],
      "~/schemas": ["../shared/schemas"],
      "~/spec": ["../shared/spec"],
      "~/icons": ["../shared/Icons"],
      "~/icons/*": ["../shared/Icons/*"],
      "~/containers/*": ["../shared/containers/*"],
      "~/widgets/*": ["../shared/widgets/*"],
      "~/Img": ["../shared/widgets/Img"],
      "~/const": ["../shared/constant/"],
      "~/const/*": ["../shared/constant/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.tsx", "**/*.ts", ".next/types/**/*.ts"]
}
