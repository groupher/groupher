{
  "compilerOptions": {
    "baseUrl": ".",
    "noUnusedLocals": true,
    "paths": {
      "~/app": ["./app"],
      "~/app/*": ["./app/*"],
      "~/auth": ["./app/auth"],
      "~/auth/*": ["./app/auth/*"],
      "~/unit": ["./unit"],
      "~/unit/*": ["./unit/*"],
      "~/widgets": ["./widgets"],
      "~/widgets/*": ["./widgets/*"],
      "~/services": ["./services"],
      "~/services/*": ["./services/*"],
      "~/const": ["./constant"],
      "~/const/*": ["./constant/*"],
      "~/constant": ["./constant"],
      "~/constant/*": ["./constant/*"],
      "~/hooks": ["./hooks"],
      "~/hooks/*": ["./hooks/*"],
      "~/config": ["./config"],
      "~/config/*": ["./config/*"],
      "~/stores": ["./stores"],
      "~/stores/*": ["./stores/*"],
      "~/lib": ["./lib"],
      "~/lib/*": ["./lib/*"],
      "~/utils": ["./lib"],
      "~/utils/*": ["./lib/*"],
      "~/server": ["./lib/api"],
      "~/server/*": ["./lib/api/*"],
      "~/css": ["./lib/css"],
      "~/css/*": ["./lib/css/*"],
      "~/schemas": ["./schemas"],
      "~/Img": ["./widgets/Img"],
      "~/SvgIcons/*": ["./widgets/SvgIcons/*"],
      "~/icons": ["./icons"],
      "~/icons/*": ["./icons/*"],
      "~/i18n": ["./lib/i18n"],
      "~/providers": ["./app/providers"],
      "~/providers/*": ["./app/providers/*"],
      "~/proxies": ["./app/proxies"],
      "~/proxies/*": ["./app/proxies/*"],
      "~/tailwind": ["./tailwind"],
      "~/tailwind/*": ["./tailwind/*"]
    }
  },
  "exclude": ["node_modules"]
}
