{
  "name": "@groupher/frontend-core",
  "version": "1.0.0",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    "./tsconfig": "./tsconfig.app.json",
    "./jsconfig": "./jsconfig.json",
    "./tailwind.config": "./tailwind.config.js",
    "./postcss.config": "./postcss.config.js",
    "./oxfmt": "./config/oxfmt.json",
    "./oxlint": "./config/oxlint.json",
    "./next.config": "./next.config.js"
  },
  "scripts": {
    "type-check": "../../node_modules/.bin/tsc --noEmit --project ./tsconfig.app.json",
    "lint": "../../node_modules/.bin/oxlint . --threads=1",
    "format": "../../node_modules/.bin/oxfmt -c ./config/oxfmt.json .",
    "format:check": "../../node_modules/.bin/oxfmt -c ./config/oxfmt.json --check .",
    "build": "echo 'skip build'"
  },
  "lint-staged": {
    "**/*.ts?(x)": "tsc-files --noEmit --project ./tsconfig.app.json"
  }
}
