{
  "$schema": "../../../node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react", "jsx-a11y", "nextjs"],
  "ignorePatterns": [
    "**/*.d.ts",
    "**/*.tsbuildinfo",
    "**/*.tsbuildinfo.*",
    "**/*.min.js",
    "**/next-env.d.ts",
    "**/node_modules/**",
    "backend/main/priv/static/**",
    "**/.next/**",
    "**/out/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/.turbo/**",
    "**/.cache/**",
    "**/.vercel/**",
    "**/storybook-static/**"
  ],
  "settings": {
    "react": {
      "version": "19.0.0",
      "componentWrapperFunctions": ["observer"]
    },
    "jsx-a11y": {
      "components": {
        "Link": "a"
      }
    }
  },
  "rules": {
    "no-alert": "error",
    "jsx-no-duplicate-props": "error",
    "jsx-key": "error",
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "no-unused-expressions": "warn",
    "react/exhaustive-deps": "off",
    "react/jsx-no-useless-fragment": "warn",
    "react/button-has-type": "warn",
    "react/no-danger": "warn",
    "react/no-array-index-key": "warn",
    "typescript/no-explicit-any": "warn",
    "typescript/no-non-null-assertion": "off",
    "unicorn/no-array-for-each": "warn",
    "unicorn/no-empty-file": "off",
    "unicorn/no-useless-fallback-in-spread": "off",
    "unicorn/no-new-array": "off",
    "no-param-reassign": "warn",
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["**//**"],
            "message": "hi Luka: Import path contains double slashes (`//`). Please normalize the path."
          }
        ]
      }
    ],
    "jsx-a11y/no-autofocus": "off",
    "jsx-a11y/click-events-have-key-events": "off",
    "jsx-a11y/no-static-element-interactions": "off",
    "jsx-a11y/prefer-tag-over-role": "off",
    "jsx-a11y/role-supports-aria-props": "off",
    "nextjs/no-head-element": "off",
    "nextjs/no-img-element": "off"
  },
  "overrides": [
    {
      "files": ["**/*.test.*", "**/*.spec.*", "**/tests/**"],
      "plugins": ["typescript", "unicorn", "oxc", "react", "jsx-a11y", "nextjs", "vitest"],
      "rules": {}
    }
  ]
}
