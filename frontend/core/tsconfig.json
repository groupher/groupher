{
  "compilerOptions": {
    "target": "ES2015",
    "module": "esnext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": false,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "noUnusedLocals": true,
    "baseUrl": ".",
    // this is for core only, other sub-app need to define it in there own tsconfig
    "paths": {
      "~/config": ["./config"],
      "~/hooks": ["./hooks"],
      "~/hooks/*": ["./hooks/*"],
      "~/stores/*": ["./stores/*"],
      "~/stores": ["./stores"],
      "~/utils": ["./utils"],
      "~/utils/*": ["./utils/*"],
      "~/server": ["./utils/api"],
      "~/server/*": ["./utils/api/*"],
      "~/signal": ["./utils/signal"],
      "~/signal/*": ["./utils/signal/*"],
      "~/dom": ["./utils/dom"],
      "~/dom/*": ["./utils/dom/*"],
      "~/logger": ["./utils/logger"],
      "~/logger/*": ["./utils/logger/*"],
      "~/fmt": ["./utils/fmt"],
      "~/fmt/*": ["./utils/fmt/*"],
      "~/oauth": ["./utils/oauth"],
      "~/oauth/*": ["./utils/oauth/*"],
      "~/helper": ["./utils/helper"],
      "~/helper/*": ["./utils/helper/*"],
      "~/wallpaper": ["./utils/wallpaper"],
      "~/wallpaper/*": ["./utils/wallpaper/*"],
      "~/i18n": ["./utils/i18n"],
      "~/i18n/*": ["./utils/i18n/*"],
      "~/validator": ["./utils/validator"],
      "~/validator/*": ["./utils/validator/*"],
      "~/mock": ["./utils/mock"],
      "~/mock/*": ["./utils/mock/*"],
      "~/css": ["./utils/css"],
      "~/css/*": ["./utils/css/*"],
      "~/schemas": ["./schemas"],
      "~/spec": ["./spec"],
      "~/icons": ["./Icons"],
      "~/icons/*": ["./Icons/*"],
      "~/containers": ["./containers"],
      "~/containers/*": ["./containers/*"],
      "~/widgets/*": ["./widgets/*"],
      "~/Img": ["./widgets/Img"],
      "~/const": ["./constant/"],
      "~/const/*": ["./constant/*"],
      "~/providers": ["../core/providers/"],
      "~/providers/*": ["../core/providers/*"],
      "~/middlewares": ["../core/middlewares/"],
      "~/middlewares/*": ["../core/middlewares/*"],
      "~/tailwind/*": ["./tailwind/*"],
      "~/tailwind": ["./tailwind"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.tsx", "**/*.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "**/*.test.ts"],
  "removeComments": true
}
