{
  "compilerOptions": {
    "baseUrl": ".",
    "noUnusedLocals": true,
    "paths": {
      "~/containers/*": ["../lib/containers/*"],
      "~/widgets/*": ["../lib/widgets/*"],
      "~/const": ["../lib/utils/constant"],
      "~/const/*": ["../lib/utils/constant/*"],
      "~/hooks": ["../lib//hooks"],
      "~/hooks/*": ["../lib/hooks/*"],
      "~/config": ["config"],
      "~/stores/*": ["../lib/stores/*"],
      "~/utils": ["../lib/utils"],
      "~/utils/*": ["../lib/utils/*"],
      "~/server": ["../lib/utils/api"],
      "~/server/*": ["../lib/utils/api/*"],
      "~/css": ["../lib/utils/css"],
      "~/css/*": ["../lib/utils/css/*"],
      "~/schemas": ["../lib/schemas"],
      "~/Img": ["../lib/widgets/Img"],
      "~/SvgIcons/*": ["../lib/widgets/SvgIcons/*"],
      "~/icons/*": ["../lib/widgets/icons/*"],
      "~/i18n": ["i18n"]
    }
  },
  "exclude": ["node_modules"]
}
