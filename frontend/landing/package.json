{
  "name": "@groupher/frontend-landing",
  "version": "1.0.3",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "ci": "cross-env NODE_ENV=ci next dev",
    "type-check": "tsc --noEmit",
    "build": "cross-env NODE_ENV=production next build",
    "start": "next start",
    "dist": "next build && next export -o \"build\"",
    "serve": "serve out",
    "info": "next info",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "../../node_modules/.bin/biome lint app/**/*.{ts,tsx}",
    "format": "../../node_modules/.bin/biome format --write ./app",
    "clean:up": "rm -rf *.tsbuildinfo"
  },
  "lint-staged": {
    "**/*.ts?(x)": "tsc-files --noEmit --project ./tsconfig.json"
  },
  "dependencies": {
    "@groupher/frontend-core": "1.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "serve": "^14.2.6"
  }
}
