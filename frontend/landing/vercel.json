{
  "routes": [
    {
      "src": "/landing/_next/static/(.*)",
      "dest": "/_next/static/$1"
    },
    {
      "src": "/landing/(.*)",
      "dest": "/$1"
    }
  ],
  "build": {
    "env": {
      "DEPLOY": "true" 
    },
    "command": "if [ \"$DEPLOY\" = \"true\" ]; then yarn build; else echo 'Skipping build'; fi"
  }
}