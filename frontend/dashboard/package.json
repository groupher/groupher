{
  "name": "@groupher/frontend-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "type-check": "../../node_modules/.bin/tsc --noEmit --project ./tsconfig.json",
    "build": "cross-env NODE_ENV=production next build --turbopack",
    "start": "cross-env NODe_ENV=production next start -p 3000",
    "dist": "next build && next export -o \"build\"",
    "info": "next info",
    "clean": "shjs ./utils/scripts/clean.js",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "../../node_modules/.bin/oxlint src --threads=1",
    "format": "../../node_modules/.bin/oxfmt -c ../core/config/oxfmt.json ./src",
    "format:check": "../../node_modules/.bin/oxfmt -c ../core/config/oxfmt.json --check ./src",
    "clean:up": "rm -rf *.tsbuildinfo"
  },
  "dependencies": {
    "@groupher/frontend-core": "1.0.0"
  },
  "lint-staged": {
    "**/*.ts?(x)": "tsc-files --noEmit --project ./tsconfig.json"
  }
}
