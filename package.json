    "tailwind-merge": "^3.3.1",
    "tailwindcss": "4.1.13",
    "tailwindcss-animated": "^2.0.0",
    "timeago-react": "3.0.7",
    "tinykeys": "^2.1.0",
    "tsparticles-confetti": "^2.12.0",
