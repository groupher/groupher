{
	"version": 2,
	"buildCommand": "yarn workspaces run build",
	"installCommand": "yarn install",
	"rewrites": [
		{ "source": "/", "destination": "/frontend/landing" },
		{ "source": "/pricing", "destination": "/frontend/landing" },
		{ "source": "/(.*)", "destination": "/frontend/main/$1" }
	],
	"headers": [
		{
			"source": "/(.+\\.png)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		}
	]
}
